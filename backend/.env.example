# ──────────────────────────────────────────────
#  Zorvyn Finance Backend — Environment Config
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Fields marked (Required) must be set for the app to start.
# Fields marked (Optional) enable extra features but aren't required.

# ── Server ──
PORT=4000                          # (Required) Server port
NODE_ENV=development               # (Required) development | production

# ── MongoDB ──
MONGODB_URI=                       # (Required) e.g. mongodb+srv://user:pass@cluster.mongodb.net
DB_NAME=zorvyn                     # (Required) Database name

# ── CORS ──
CORS_ORIGIN=http://localhost:3000  # (Required) Frontend URL for CORS
FRONTEND_URL=http://localhost:3000 # (Required) Used in email verification links

# ── JWT Auth ──
ACCESS_TOKEN_SECRET=               # (Required) Any random string — used to sign JWTs
ACCESS_TOKEN_EXPIRY=15m            # (Required) Access token lifetime
REFRESH_TOKEN_SECRET=              # (Required) Any random string — used to sign refresh tokens
REFRESH_TOKEN_EXPIRY=7d            # (Required) Refresh token lifetime

# ── Google OAuth ──
GOOGLE_CLIENT_ID=                  # (Optional) Google OAuth client ID
GOOGLE_CLIENT_SECRET=              # (Optional) Google OAuth client secret

# ── Email (Gmail SMTP) ──
GMAIL_USER=                        # (Optional) Gmail address for sending emails
GMAIL_PASS=                        # (Optional) Gmail app password (not your regular password)

# ── Cloudinary ──
CLOUDINARY_CLOUD_NAME=             # (Optional) For profile image uploads
CLOUDINARY_API_KEY=                # (Optional)
CLOUDINARY_API_SECRET=             # (Optional)

# ── Google Gemini AI ──
GEMINI_API_KEY=                    # (Optional) For AI receipt scanning & financial insights

# ── Arcjet ──
ARCJET_API_KEY=                    # (Optional) For rate limiting & bot detection
